# Required — copy to .env and fill in values

# IBKR connection
IBKR_HOST=127.0.0.1
IBKR_PORT=4002
IBKR_ACCOUNT=

# Client ID used by this monitor process (must differ from your trading bot)
MONITOR_CLIENT_ID=3

# Optional Telegram alerts (every 60 s)
TELEGRAM_NOTIFICATIONS_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
